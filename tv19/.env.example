# ============================================================
#  TV19 NEWS - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values

# ============================================================
#  REQUIRED ENVIRONMENT VARIABLES
# ============================================================

# MongoDB Connection String
# Example: mongodb://localhost:27017/newsTV19 or MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017/newsTV19

# JWT Secret Key - MUST be set for production!
# Generate with: openssl rand -hex 32 or node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is used for signing admin authentication tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================
#  OPTIONAL ENVIRONMENT VARIABLES
# ============================================================

# Server Configuration
PORT=5000

# CORS - Comma-separated list of allowed origins
# Example: http://localhost:5173,https://tv19.com
ALLOWED_ORIGINS=http://localhost:5173

# Backend and Frontend URLs (used in email verification links)
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ============================================================
#  EMAIL CONFIGURATION (for admin verification)
# ============================================================
# Gmail SMTP credentials for sending verification emails
# Use Gmail App Password, not your regular password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# ============================================================
#  EXTERNAL API KEYS
# ============================================================

# WeatherAPI.com key for weather widget (frontend)
VITE_WEATHER_API_KEY=your-weather-api-key

# ============================================================
#  SECURITY NOTES:
# ============================================================
# 1. NEVER commit .env file to version control
# 2. JWT_SECRET should be 32+ random characters in production
# 3. Use App Password for Gmail (not your regular password)
# 4. MongoDB must be running before starting the server
# ============================================================
